{
  "compilerOptions": {
    "target": "es2022",  
    "module": "es2022",
    "types": ["node"], // for node types 
      //npm install -D @types/node
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist"

    //npm install -D @types/node

  },
  "include": ["src"]
}